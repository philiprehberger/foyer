<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Integration">
            <directory>tests/Integration</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array"/>
        <!-- Integration tests against Postgres rely on env-supplied DB creds.
             Unit tests that don't hit the EXCLUDE constraints can fall back to
             sqlite — but the slot-hold concurrency test SHOULD be skipped if
             pgsql is not available (see SlotHoldConcurrencyTest::setUp). -->
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_DATABASE" value="foyer_test"/>
        <env name="DB_USERNAME" value="foyer"/>
        <env name="DB_PASSWORD" value=""/>
        <env name="DB_SCHEMA" value="public"/>
        <env name="DB_URL" value=""/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="FOYER_INTERNAL_SECRET" value="test-secret-32-chars-long-xxxxxx"/>
        <env name="FOYER_AGENT_WORKER_URL" value="http://127.0.0.1:8800"/>
    </php>
</phpunit>
