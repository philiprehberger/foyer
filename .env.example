APP_NAME="Foyer"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=foyer
DB_USERNAME=foyer
DB_PASSWORD=
DB_SCHEMA=foyer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=foyer

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

# ---------------------------------------------------------------------------
# Foyer-specific
# ---------------------------------------------------------------------------

# Internal HMAC for Laravel <-> FastAPI worker. Generate with: openssl rand -hex 32
FOYER_INTERNAL_SECRET=
FOYER_INTERNAL_BIND=127.0.0.1
FOYER_AGENT_WORKER_URL=http://127.0.0.1:8800
# Base URL the FastAPI agent worker uses to call back into Laravel's
# /_internal/* endpoints. 127.0.0.1 only — never expose publicly.
FOYER_LARAVEL_INTERNAL_BASE_URL=http://127.0.0.1:8000

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_STATUS_CALLBACK_URL=

# Google APIs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_MAPS_API_KEY=
GOOGLE_GEOCODING_API_KEY=

# LLM (FastAPI agent worker reads these). Provider: mock | anthropic | openai
FOYER_LLM_PROVIDER=mock
FOYER_LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Cost ceilings (per business per day in micros — 1_000_000 micros = $1.00)
FOYER_DEFAULT_COST_CEILING_MICROS=500000

# Photo pipeline
FOYER_PHOTOS_BUCKET=foyer-photos
FOYER_PHOTOS_REGION=us-west-2

# Sentry
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Demo abuse protections
FOYER_DEMO_BUSINESS_SLUG=anchor-plumbing
FOYER_DEMO_DAILY_LIMIT_PER_NUMBER=3
FOYER_DEMO_TWILIO_DAILY_SPEND_CEILING=10000

# Quiet hours default (FCC-aligned)
FOYER_DEFAULT_QUIET_START=21:00
FOYER_DEFAULT_QUIET_END=08:00

# Slot hold
FOYER_SLOT_HOLD_MINUTES=15
